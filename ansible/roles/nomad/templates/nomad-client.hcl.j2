log_level            = "DEBUG"
log_include_location = true
log_file             = "/var/log/nomad.log"
enable_debug         = true

datacenter = "{{ nomad_datacenter }}"
region     = "{{ nomad_region }}"
data_dir   = "{{ nomad_data_dir }}"

bind_addr = "0.0.0.0"

advertise {
  http = "{{ ansible_facts['default_ipv4']['address'] }}:4646"
  rpc  = "{{ ansible_facts['default_ipv4']['address'] }}:4647"
  serf = "{{ ansible_facts['default_ipv4']['address'] }}:4648"
}

server {
  enabled = false
}

client {
  enabled = true

  server_join {
    retry_join = [
{% for host in groups['servers'] %}
      "{{ hostvars[host]['private_ip'] }}"{{ "," if not loop.last else "" }}
{% endfor %}
    ]
  }

  network_interface = "{{ nomad_client_network_interface }}"

  host_volume "data" {
    path      = "/opt/nomad/data/volumes"
    read_only = false
  }
}

consul {
  address             = "{{ nomad_consul_address }}"
  client_service_name = "{{ nomad_consul_client_service_name }}"
  client_auto_join    = {{ nomad_consul_client_auto_join | lower }}
  auto_advertise      = {{ nomad_consul_auto_advertise | lower }}
}

telemetry {
  publish_allocation_metrics = true
  publish_node_metrics       = true
}

